APP_ENV=local
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_TOKEN=replace-with-preview-wrangler-secret-generated-by-openssl-rand-base64-32
PREVIEW_DEMO_SEED_ENABLED=false
PREVIEW_DEMO_SEED_TOKEN=replace-with-temporary-preview-seed-token
AUTH_ALLOW_SIGNUP=true
AUTH_ENABLED=true
BETTER_AUTH_SECRET=replace-with-output-from-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:5173
BUILD_WEEK_DEMO_MODE=true
BUILD_WEEK_INTEGRITY_ENABLED=true
BUILD_WEEK_INTEGRITY_LIVE_ENABLED=false
OPENAI_API_KEY=replace-with-an-openai-project-api-key-before-enabling-live-reviews
ENABLE_DEV_CASE_API=true
